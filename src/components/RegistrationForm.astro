---
// RegistrationForm.astro — founding interest sign-up form
//
// FORM PROVIDER SETUP (Formspree — recommended)
// -----------------------------------------------
// 1. Create a free account at https://formspree.io
// 2. Create a new form and copy your endpoint URL, e.g.:
//      https://formspree.io/f/abcdefgh
// 3. Replace the FORMSPREE_ENDPOINT value below with your URL.
//
// That's it. The form uses fetch() so the visitor never leaves the page.
// All submissions appear in your Formspree dashboard and are emailed to you.
//
// OTHER PROVIDERS
// ---------------
// Netlify Forms: add  data-netlify="true" name="interest"  to the <form> tag
//   and remove the <script> block below.
// Tally: replace this entire component with your Tally iframe embed code.
//
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/mqenvybp';
---

<section class="form-section" id="interest" aria-label="Register your interest">
  <div class="container">
    <article class="form-inner">
      <hgroup>
        <p class="section-label">Put Your Hand Up</p>
        <h2 class="section-title">Join the<br /><em>Founding List</em></h2>
        <p class="section-body">
          Tell us who you are and how you might like to be involved. Every response helps measure
          whether Spotsylvania Rugby Football Club can move from idea to reality.
        </p>
      </hgroup>

      <div class="success-msg" id="successMsg" role="status" aria-live="polite">
        <strong>Thanks — you are on the founding list.</strong> We will be in touch as interest builds.
        The next step would be an interest meeting and a clearer plan for players, families, volunteers,
        and supporters.
      </div>

      <form class="interest-form" id="interestForm" action={FORMSPREE_ENDPOINT} method="POST">
        <div class="form-row">
          <div class="field-group">
            <label for="fname">First Name</label>
            <input type="text" id="fname" name="firstname" placeholder="James" required />
          </div>
          <div class="field-group">
            <label for="lname">Last Name</label>
            <input type="text" id="lname" name="lastname" placeholder="McAllister" required />
          </div>
        </div>

        <div class="form-row">
          <div class="field-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="james@example.com" required />
          </div>
          <div class="field-group">
            <label for="phone">Phone Number <small>(optional)</small></label>
            <input type="tel" id="phone" name="phone" placeholder="(555) 555-5555" />
          </div>
        </div>

        <div class="form-row">
          <div class="field-group">
            <label for="age">Participant Age / Grade</label>
            <select id="age" name="age">
              <option value="">Select…</option>
              <option>Parent / guardian</option>
              <option>Elementary — K–2nd grade</option>
              <option>Elementary — 3rd–5th grade</option>
              <option>Middle school — 6th–8th grade</option>
              <option>High school — 9th–10th grade</option>
              <option>High school — 11th–12th grade</option>
              <option>Adult — 18–34</option>
              <option>Adult — 35–49</option>
              <option>Adult — 50+</option>
              <option>Coach / volunteer / referee</option>
              <option>Sponsor / supporter</option>
            </select>
            <p class="field-hint">
              Youth groups will be organized by age, grade, and registration requirements once
              interest is measured.
            </p>
          </div>
          <div class="field-group">
            <label for="experience">Rugby Experience</label>
            <select id="experience" name="experience">
              <option value="">Select…</option>
              <option>None — complete beginner</option>
              <option>Watched and interested</option>
              <option>Played recreationally</option>
              <option>Played at school or club level</option>
              <option>Played at competitive level</option>
              <option>Coached or refereed</option>
            </select>
          </div>
        </div>

        <div class="field-group">
          <label for="role">How would you like to be involved?</label>
          <select id="role" name="role">
            <option value="">Select…</option>
            <option>Player</option>
            <option>Parent of a potential player</option>
            <option>Coach or assistant coach</option>
            <option>Referee</option>
            <option>Volunteer / team manager</option>
            <option>Athletic trainer / medic</option>
            <option>Sponsor or local business</option>
            <option>Supporter / fan</option>
          </select>
        </div>

        <div class="field-group">
          <label for="message">Anything else you'd like to share? <small>(optional)</small></label>
          <textarea
            id="message"
            name="message"
            placeholder="Questions, ideas, or just a word of support…"></textarea>
        </div>

        <button type="submit" class="btn-primary" id="submitBtn"> Join the Founding List </button>

        <p class="form-error" id="formError" role="alert" aria-live="assertive"></p>

        <p class="microcopy">
          No commitment required. This list is simply the first practical step toward an interest
          meeting, early training plans, and a possible first season.
        </p>
      </form>
    </article>
  </div>
</section>

<script>
  const form = document.getElementById('interestForm') as HTMLFormElement;
  const success = document.getElementById('successMsg') as HTMLElement;
  const errEl = document.getElementById('formError') as HTMLElement;
  const btn = document.getElementById('submitBtn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errEl.textContent = '';
    btn.disabled = true;
    btn.textContent = 'Sending…';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.style.display = 'none';
        success.style.display = 'block';
        success.setAttribute('tabindex', '-1');
        success.focus();
        success.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } else {
        const data = await res.json().catch(() => ({}));
        errEl.textContent =
          (data as any)?.error || 'Something went wrong. Please try again or email us directly.';
        btn.disabled = false;
        btn.textContent = 'Join the Founding List';
      }
    } catch {
      errEl.textContent = 'Network error. Please check your connection and try again.';
      btn.disabled = false;
      btn.textContent = 'Join the Founding List';
    }
  });
</script>
