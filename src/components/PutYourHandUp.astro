---
// PutYourHandUp.astro — founding campaign section
---

<section class="campaign-section" id="put-your-hand-up">
  <div class="campaign-inner">
    <p class="section-label">Founding Campaign</p>
    <h2 class="section-title">Put Your <em>Hand Up</em></h2>
    <p class="section-body">
      A rugby club is built by the people willing to step forward first.
      Whether you are a parent, player, coach, referee, sponsor, teacher,
      volunteer, or supporter, your interest helps determine what
      Spotsylvania RFC can become.
    </p>
    <a href="#interest" class="btn-primary">Join the Founding List</a>
  </div>
</section>

<style>
  .campaign-section {
    background: var(--light);
    border-top: 1px solid rgba(13, 31, 45, .08);
    border-bottom: 1px solid rgba(13, 31, 45, .08);
    padding: 88px 24px;
  }

  .campaign-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .campaign-inner .section-body {
    margin-bottom: 34px;
  }

  @media (max-width: 760px) {
    .campaign-section {
      padding: 64px 20px;
    }
  }
</style>
