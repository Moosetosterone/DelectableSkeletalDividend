---
// Header.astro — fixed top navigation bar
const path = Astro.url.pathname;
const is = (stem: string) =>
  stem === '/' ? path === '/' : path.startsWith(stem);
---

<a class="skip-link" href="#main-content">Skip to main content</a>

<nav class="container-fluid" aria-label="Main navigation">
  <ul>
    <li><strong>Spotsylvania RFC</strong></li>
  </ul>
  <ul>
    <li><a href="/" class={is('/') ? 'nav-active' : undefined}>Home</a></li>
    <li><a href="/about" class={is('/about') ? 'nav-active' : undefined}>About</a></li>
    <li><a href="/rugby-101" class={is('/rugby-101') ? 'nav-active' : undefined}>Rugby 101</a></li>
    <li><a href="/get-involved" class={is('/get-involved') ? 'nav-active' : undefined}>Get Involved</a></li>
    <li><a href="/news" class={is('/news') ? 'nav-active' : undefined}>News</a></li>
    <li><a href="/#interest" role="button">Join the Founding List</a></li>
  </ul>
</nav>

<style>
  nav a.nav-active {
    color: var(--gold);
  }

  @media (max-width: 960px) {
    nav ul:last-child li:nth-child(-n + 5) {
      display: none;
    }
  }
</style>
