---
// Header.astro — fixed top navigation bar
const path = Astro.url.pathname;
const isHome = path === '/';
---

<a class="skip-link" href="#main-content">Skip to main content</a>

<nav class="container-fluid" aria-label="Main navigation">
  <ul>
    <li><strong>Spotsylvania RFC</strong></li>
  </ul>
  <ul>
    <li><a href="/#youth" class={isHome ? 'nav-active' : undefined}>Youth Tag Rugby</a></li>
    <li><a href="/#vision" class={isHome ? 'nav-active' : undefined}>Vision</a></li>
    <li><a href="/#interest" role="button">Join the Founding List</a></li>
  </ul>
</nav>

<style>
  nav a.nav-active {
    color: var(--gold);
  }

  @media (max-width: 760px) {
    nav ul:last-child li:nth-child(-n + 2) {
      display: none;
    }
  }
</style>
