---
// index.astro — Spotsylvania RFC founding interest landing page
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import YouthTagRugby from '../components/YouthTagRugby.astro';
import Pillars from '../components/Pillars.astro';
import StripeQuote from '../components/StripeQuote.astro';
import ParentFAQ from '../components/ParentFAQ.astro';
import PutYourHandUp from '../components/PutYourHandUp.astro';
import InterestSection from '../components/InterestSection.astro';
import RegistrationForm from '../components/RegistrationForm.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Header />

  <main id="main-content">
    <Hero />
    <YouthTagRugby />
    <Pillars />
    <StripeQuote />
    <ParentFAQ />
    <PutYourHandUp />
    <InterestSection />
  </main>

  <RegistrationForm />
  <Footer />
</BaseLayout>
