---
// culpeper.astro — Practice build: Culpeper Youth Rugby Football Club
// PRACTICE BUILD ONLY — not the official CYRFC site.
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Culpeper Youth Rugby Football Club"
  description="Youth rugby for Culpeper and surrounding counties. Pre-K through High School. Tag and tackle rugby in a welcoming, development-focused environment."
  ogTitle="Culpeper Youth Rugby Football Club"
  ogDescription="Register for Summer 2026 Rugby. New and returning players welcome. Pre-K through High School."
>
  <div class="cy">
    <!-- ===================== NAV ===================== -->
    <nav class="cy-nav" aria-label="Site navigation">
      <a href="/culpeper" class="cy-nav-brand">
        <img
          src="/assets/culpeper/cropped-CYRC-1-white.png"
          alt="Culpeper Rugby Football Club crest"
          class="cy-nav-logo"
        />
        <span class="cy-nav-wordmark">Culpeper Youth Rugby</span>
      </a>
      <button
        class="cy-nav-toggle"
        aria-controls="cy-nav-menu"
        aria-expanded="false"
        aria-label="Open navigation"
      >
        <span></span><span></span><span></span>
      </button>
      <ul class="cy-nav-links" id="cy-nav-menu">
        <li><a href="#season">Season</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#principles">Principles</a></li>
        <li><a href="#rugby">Rugby 101</a></li>
        <li><a href="#involved">Get Involved</a></li>
        <li><a href="#contact" class="cy-nav-cta">Register</a></li>
      </ul>
    </nav>

    <!-- ===================== HERO ===================== -->
    <section class="cy-hero" id="top">
      <div class="cy-hero-inner">
        <img
          src="/assets/culpeper/cropped-CYRC-1-white.png"
          alt="Culpeper Rugby Football Club crest"
          class="cy-hero-crest"
        />
        <h1 class="cy-hero-title">Youth Rugby<br />in Culpeper.</h1>
        <p class="cy-hero-sub">
          New and returning players welcome.<br class="cy-br" />
          Rugby for youth athletes from Pre-K through High School.
        </p>
        <div class="cy-hero-actions">
          <a href="#contact" class="cy-btn cy-btn--gold">Register for Summer Rugby</a>
          <a href="#rugby" class="cy-btn cy-btn--outline">Learn About Rugby</a>
        </div>
      </div>
      <div class="cy-hero-scroll" aria-hidden="true">
        <span class="cy-hero-scroll-line"></span>
      </div>
    </section>

    <!-- ===================== CURRENT SEASON ===================== -->
    <section class="cy-section cy-section--navy-mid" id="season">
      <div class="cy-container">
        <div class="cy-section-label">Current Season</div>
        <h2 class="cy-section-title">Summer 2026 <em>Rugby</em></h2>
        <p class="cy-section-body">
          Spring 2026 registered players are automatically enrolled for summer — no additional
          registration required.
        </p>
        <div class="cy-schedule">
          <div class="cy-sched-card">
            <div class="cy-sched-date">May 26</div>
            <div class="cy-sched-event">Practices Begin</div>
          </div>
          <div class="cy-sched-card cy-sched-card--accent">
            <div class="cy-sched-date">June 6</div>
            <div class="cy-sched-event">Season Kickoff</div>
          </div>
          <div class="cy-sched-card cy-sched-card--dim">
            <div class="cy-sched-date">July 5</div>
            <div class="cy-sched-event">No Games</div>
          </div>
          <div class="cy-sched-card cy-sched-card--gold">
            <div class="cy-sched-date">July 11</div>
            <div class="cy-sched-event">Championships</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== ABOUT ===================== -->
    <section class="cy-section cy-section--light" id="about">
      <div class="cy-container">
        <div class="cy-section-label cy-section-label--dark">About the Club</div>
        <h2 class="cy-section-title cy-section-title--dark">
          A rugby club for <em>Culpeper</em><br />and the surrounding region.
        </h2>
        <p class="cy-section-body cy-section-body--dark">
          Culpeper Youth Rugby Football Club is open to players from Culpeper and surrounding
          counties, from Pre-K through High School. No prior experience is needed at any age group.
          Our programme is built to welcome beginners and develop players at every stage.
        </p>

        <div class="cy-about-grid">
          <div class="cy-about-item">
            <div class="cy-about-icon">◈</div>
            <h3>Tag Rugby</h3>
            <p>
              Younger players learn the game through non-contact tag rugby — defenders pull a belt
              tag instead of tackling. It's the USA Rugby youth pathway entry point, and it's
              genuinely fun.
            </p>
          </div>
          <div class="cy-about-item">
            <div class="cy-about-icon">◈</div>
            <h3>Tackle Rugby</h3>
            <p>
              Tackle formats are introduced progressively for older age groups with proper coaching,
              USA Rugby safety guidelines, and technique-first training.
            </p>
          </div>
          <div class="cy-about-item">
            <div class="cy-about-icon">◈</div>
            <h3>All Levels Welcome</h3>
            <p>
              Whether your player has never seen a rugby match or has seasons of experience, they
              start at the right level. Coaches work from the ground up.
            </p>
          </div>
          <div class="cy-about-item">
            <div class="cy-about-icon">◈</div>
            <h3>Development-First</h3>
            <p>
              We prioritise skill, confidence, and character over results. Rugby's team culture
              naturally reinforces the values we want young athletes to carry off the pitch.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== PRINCIPLES ===================== -->
    <section class="cy-section cy-section--navy-dark" id="principles">
      <div class="cy-container">
        <div class="cy-section-label">Club Principles</div>
        <h2 class="cy-section-title">What we <em>stand for.</em></h2>
        <div class="cy-principles">
          <div class="cy-principle">
            <div class="cy-principle-roman">I</div>
            <h3 class="cy-principle-name">Unity</h3>
            <p>Working together towards the same goal — through triumphs and struggles.</p>
          </div>
          <div class="cy-principle">
            <div class="cy-principle-roman">II</div>
            <h3 class="cy-principle-name">Courage</h3>
            <p>Overcoming obstacles through teamwork and preparation.</p>
          </div>
          <div class="cy-principle">
            <div class="cy-principle-roman">III</div>
            <h3 class="cy-principle-name">Respect</h3>
            <p>Showing positivity to others on and off the pitch.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== RUGBY 101 ===================== -->
    <section class="cy-section" id="rugby">
      <div class="cy-container">
        <div class="cy-section-label">For Parents</div>
        <h2 class="cy-section-title">
          Rugby is more beginner-friendly<br /><em>than most parents expect.</em>
        </h2>
        <p class="cy-section-body">
          If your first question is "I don't know anything about rugby — will that be a problem?" —
          the answer is no. Here is what to know before your player's first session.
        </p>

        <div class="cy-rugby-grid">
          <div class="cy-rugby-block">
            <div class="cy-rugby-num">01</div>
            <h3 class="cy-rugby-title">No experience required</h3>
            <p>
              Rugby coaching starts from zero. Coaches introduce rules, skills, and positions
              gradually. A player who has never seen a rugby match won't be out of place — that
              describes most players at their first session.
            </p>
          </div>
          <div class="cy-rugby-block">
            <div class="cy-rugby-num">02</div>
            <h3 class="cy-rugby-title">Teamwork over individual talent</h3>
            <p>
              Rugby rewards communication, decision-making, and covering teammates — not just speed
              or size. Players who struggle to stand out in individual-heavy sports often find their
              best home in rugby.
            </p>
          </div>
          <div class="cy-rugby-block">
            <div class="cy-rugby-num">03</div>
            <h3 class="cy-rugby-title">Builds real confidence</h3>
            <p>
              The physical demands — running, catching, spatial awareness, contact appropriate to
              age — build the kind of whole-body confidence that carries over to school and life.
            </p>
          </div>
          <div class="cy-rugby-block">
            <div class="cy-rugby-num">04</div>
            <h3 class="cy-rugby-title">Sportsmanship is enforced</h3>
            <p>
              Respect for opponents, referees, and teammates isn't a stated value — it's enforced at
              every level of the sport. Players learn that the culture and the game are inseparable.
            </p>
          </div>
          <div class="cy-rugby-block">
            <div class="cy-rugby-num">05</div>
            <h3 class="cy-rugby-title">First practice is low-pressure</h3>
            <p>
              Expect warm-ups, basic passing drills, a small-sided game or tag play, and a
              cool-down. Players move a lot, laugh often, and leave tired in a good way. Cleats help
              — everything else we can work around.
            </p>
          </div>
          <div class="cy-rugby-block">
            <div class="cy-rugby-num">06</div>
            <h3 class="cy-rugby-title">A position for every shape</h3>
            <p>
              Rugby has forwards and backs — different roles, different skill sets, different body
              types. A player who doesn't fit the mould for one sport usually finds their place
              naturally in rugby.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== GET INVOLVED ===================== -->
    <section class="cy-section cy-section--navy-mid" id="involved">
      <div class="cy-container">
        <div class="cy-section-label">Get Involved</div>
        <h2 class="cy-section-title">Every role <em>matters.</em></h2>
        <p class="cy-section-body">
          A youth rugby club runs on more than players. If any of these roles fit, we want to hear
          from you.
        </p>

        <div class="cy-roles">
          <div class="cy-role">
            <div class="cy-role-label">Player</div>
            <p>
              Youth players, Pre-K through High School. New and returning welcome at every age
              group.
            </p>
            <a href="#contact" class="cy-role-link">Register →</a>
          </div>
          <div class="cy-role">
            <div class="cy-role-label">Parent</div>
            <p>
              Help with session logistics, coordination, chaperoning, and keeping the programme
              running week to week.
            </p>
            <a href="#contact" class="cy-role-link">Get in touch →</a>
          </div>
          <div class="cy-role">
            <div class="cy-role-label">Coach</div>
            <p>
              Rugby experience helpful but not required. Coaches from other sports are welcome.
              Training and certification support available.
            </p>
            <a href="#contact" class="cy-role-link">Get in touch →</a>
          </div>
          <div class="cy-role">
            <div class="cy-role-label">Volunteer</div>
            <p>
              Field setup, event support, administration — every hour contributed helps the
              programme operate smoothly.
            </p>
            <a href="#contact" class="cy-role-link">Get in touch →</a>
          </div>
          <div class="cy-role">
            <div class="cy-role-label">Sponsor</div>
            <p>
              Local businesses that support the club help fund kit, equipment, field costs, and
              player development.
            </p>
            <a href="#contact" class="cy-role-link">Get in touch →</a>
          </div>
          <div class="cy-role">
            <div class="cy-role-label">Supporter</div>
            <p>
              Want to follow the club and see it grow? That support matters too. Stay connected with
              the programme.
            </p>
            <a href="#contact" class="cy-role-link">Stay connected →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== CONTACT / REGISTER ===================== -->
    <section class="cy-section cy-section--light" id="contact">
      <div class="cy-container cy-container--form">
        <div class="cy-section-label cy-section-label--dark">Register &amp; Contact</div>
        <h2 class="cy-section-title cy-section-title--dark">
          Put your name <em>forward.</em>
        </h2>
        <p class="cy-section-body cy-section-body--dark">
          Fill in the form and the club will be in touch. New players, parents, coaches, and
          volunteers are all welcome to reach out.
        </p>

        <div class="cy-notice" role="note">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="7.5" stroke="currentColor"></circle>
            <path d="M8 5v4M8 11v.5" stroke="currentColor" stroke-linecap="round"></path>
          </svg>
          <span>
            <strong>Practice build only</strong> — replace with official CYRFC registration/contact workflows
            before launch.
          </span>
        </div>

        <form class="cy-form" onsubmit="return false;" aria-label="Register or contact the club">
          <div class="cy-form-row">
            <div class="cy-field">
              <label for="cy-name">Full Name</label>
              <input
                type="text"
                id="cy-name"
                name="name"
                autocomplete="name"
                placeholder="Your name"
              />
            </div>
            <div class="cy-field">
              <label for="cy-email">Email Address</label>
              <input
                type="email"
                id="cy-email"
                name="email"
                autocomplete="email"
                placeholder="your@email.com"
              />
            </div>
          </div>
          <div class="cy-field">
            <label for="cy-grade">Player Age / Grade</label>
            <input
              type="text"
              id="cy-grade"
              name="grade"
              placeholder="e.g. Age 9, Grade 4 — or 'Parent / Coach / Volunteer'"
            />
          </div>
          <div class="cy-field">
            <label for="cy-message">Message <span class="cy-field-optional">(optional)</span></label
            >
            <textarea
              id="cy-message"
              name="message"
              rows="4"
              placeholder="Questions, availability, role you're interested in…"></textarea>
          </div>
          <button
            type="submit"
            class="cy-btn cy-btn--gold cy-btn--disabled"
            disabled
            aria-disabled="true"
          >
            Submit — Form Not Yet Active
          </button>
        </form>
      </div>
    </section>

    <!-- ===================== FOOTER ===================== -->
    <footer class="cy-footer">
      <div class="cy-footer-brand">
        <img
          src="/assets/culpeper/cropped-CYRC-1-white.png"
          alt=""
          aria-hidden="true"
          class="cy-footer-logo"
        />
        <span>Culpeper Youth Rugby Football Club</span>
      </div>
      <p class="cy-footer-region">Culpeper, Virginia &amp; Surrounding Counties</p>
      <p class="cy-footer-notice">Practice build — not the official CYRFC website.</p>
    </footer>
  </div><!-- /.cy -->

  <!-- Mobile nav toggle -->
  <script>
    const toggle = document.querySelector('.cy-nav-toggle');
    const menu = document.getElementById('cy-nav-menu');
    if (toggle && menu) {
      toggle.addEventListener('click', () => {
        const open = menu.classList.toggle('cy-nav-open');
        toggle.setAttribute('aria-expanded', String(open));
      });
      menu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          menu.classList.remove('cy-nav-open');
          toggle.setAttribute('aria-expanded', 'false');
        });
      });
    }
  </script>
</BaseLayout>

<style>
  /* =================================================================
   CULPEPER YOUTH RFC — PAGE STYLES
   Scoped inside .cy to avoid collision with Spotsylvania RFC.
   Color tokens:
     Navy      #0A1F3C
     Gold      #C8973A
     White     #FFFFFF
     LightGray #F4F4F4
     SkyBlue   #5B9BD5
     Red       #C0392B
================================================================= */

  /* Reset & base */
  .cy * {
    box-sizing: border-box;
  }
  .cy {
    background: #0a1f3c;
    color: #fff;
    font-family: 'Libre Baskerville', Georgia, serif;
  }
  .cy h1,
  .cy h2,
  .cy h3 {
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    margin: 0;
  }
  .cy p {
    margin: 0;
  }
  .cy a {
    text-decoration: none;
  }

  /* ---- Nav -------------------------------------------------------- */
  .cy-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 28px;
    height: 64px;
    background: rgba(10, 31, 60, 0.96);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(200, 151, 58, 0.18);
  }

  .cy-nav-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #fff;
  }
  .cy-nav-logo {
    height: 38px;
    width: auto;
    display: block;
  }
  .cy-nav-wordmark {
    font-family: 'Oswald', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #c8973a;
  }

  .cy-nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .cy-nav-links a {
    font-family: 'Oswald', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    padding: 6px 10px;
    transition: color 0.15s;
  }
  .cy-nav-links a:hover {
    color: #c8973a;
  }
  .cy-nav-cta {
    background: #c8973a !important;
    color: #0a1f3c !important;
    padding: 8px 18px !important;
    margin-left: 8px;
    font-weight: 700 !important;
  }
  .cy-nav-cta:hover {
    background: #d9a94a !important;
  }

  /* Hamburger */
  .cy-nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 4px;
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .cy-nav-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: #fff;
    transition: opacity 0.2s;
  }

  /* ---- Hero ------------------------------------------------------- */
  .cy-hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 110px 24px 80px;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(91, 155, 213, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 50% 100%, rgba(200, 151, 58, 0.07) 0%, transparent 55%),
      #0a1f3c;
    position: relative;
  }
  .cy-hero-inner {
    max-width: 720px;
  }
  .cy-hero-crest {
    width: min(200px, 42vw);
    height: auto;
    margin: 0 auto 32px;
    filter: drop-shadow(0 8px 32px rgba(0, 0, 0, 0.55));
  }
  .cy-hero-title {
    font-size: clamp(2.6rem, 7vw, 5rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: #fff;
    margin-bottom: 20px;
  }
  .cy-hero-sub {
    font-size: clamp(1rem, 2.2vw, 1.15rem);
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 40px;
  }
  .cy-br {
    display: inline;
  }
  .cy-hero-actions {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cy-hero-scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
  }
  .cy-hero-scroll-line {
    display: block;
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, rgba(200, 151, 58, 0.6), transparent);
    margin: 0 auto;
    animation: cy-scroll-pulse 2.2s ease-in-out infinite;
  }
  @keyframes cy-scroll-pulse {
    0%,
    100% {
      opacity: 0.3;
      transform: scaleY(0.8);
    }
    50% {
      opacity: 1;
      transform: scaleY(1);
    }
  }

  /* ---- Buttons ---------------------------------------------------- */
  .cy-btn {
    display: inline-block;
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 14px 36px;
    transition:
      background 0.15s,
      color 0.15s,
      border-color 0.15s;
    cursor: pointer;
    border: 2px solid transparent;
  }
  .cy-btn--gold {
    background: #c8973a;
    color: #0a1f3c;
    border-color: #c8973a;
  }
  .cy-btn--gold:hover {
    background: #d9a94a;
    border-color: #d9a94a;
  }
  .cy-btn--outline {
    background: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.4);
  }
  .cy-btn--outline:hover {
    border-color: #c8973a;
    color: #c8973a;
  }
  .cy-btn--disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  /* ---- Section base ----------------------------------------------- */
  .cy-section {
    padding: 100px 24px;
  }
  .cy-section--navy-dark {
    background: rgba(0, 0, 0, 0.25);
  }
  .cy-section--navy-mid {
    background: rgba(0, 0, 0, 0.15);
  }
  .cy-section--light {
    background: #f4f4f4;
  }

  .cy-container {
    max-width: 1100px;
    margin: 0 auto;
  }
  .cy-container--form {
    max-width: 720px;
  }

  .cy-section-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #c8973a;
    margin-bottom: 16px;
  }
  .cy-section-label--dark {
    color: #9a7030;
  }

  .cy-section-title {
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 1.1;
    color: #fff;
    margin-bottom: 20px;
  }
  .cy-section-title em {
    font-style: italic;
    color: #c8973a;
  }
  .cy-section-title--dark {
    color: #0a1f3c;
  }
  .cy-section-title--dark em {
    color: #9a7030;
  }

  .cy-section-body {
    font-size: 1rem;
    line-height: 1.9;
    color: rgba(255, 255, 255, 0.6);
    max-width: 600px;
    margin-bottom: 56px;
  }
  .cy-section-body--dark {
    color: rgba(10, 31, 60, 0.65);
  }

  /* ---- Schedule --------------------------------------------------- */
  .cy-schedule {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3px;
  }
  .cy-sched-card {
    background: rgba(255, 255, 255, 0.05);
    border-top: 3px solid rgba(200, 151, 58, 0.25);
    padding: 32px 24px;
  }
  .cy-sched-card--accent {
    border-top-color: #5b9bd5;
  }
  .cy-sched-card--gold {
    border-top-color: #c8973a;
  }
  .cy-sched-card--dim {
    opacity: 0.5;
  }

  .cy-sched-date {
    font-family: 'Oswald', sans-serif;
    font-size: 1.9rem;
    font-weight: 700;
    color: #c8973a;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }
  .cy-sched-card--accent .cy-sched-date {
