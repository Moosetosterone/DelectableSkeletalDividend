---
// culpeper.astro — Practice build: Culpeper Youth Rugby Football Club
// PRACTICE BUILD ONLY — not the official CYRFC site.
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Culpeper Youth Rugby Football Club"
  description="Youth rugby for Culpeper and surrounding counties. Pre-K through high school. Tag and tackle rugby in a welcoming, development-focused environment."
  ogTitle="Culpeper Youth Rugby Football Club"
  ogDescription="Register for Summer 2026 Rugby. New and returning players welcome. Pre-K through high school."
>
  <div class="cy-page">

    <!-- Nav -->
    <nav class="cy-nav" aria-label="Culpeper Youth Rugby navigation">
      <a href="/culpeper" class="cy-brand">
        <img src="/assets/culpeper/culpeper-logo.png" alt="Culpeper Rugby Football Club crest" class="cy-nav-logo" />
        <span>Culpeper Youth Rugby</span>
      </a>
      <ul class="cy-nav-links">
        <li><a href="#season">Season</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#rugby">Rugby 101</a></li>
        <li><a href="#involved">Get Involved</a></li>
        <li><a href="#contact" class="cy-nav-btn">Register</a></li>
      </ul>
    </nav>

    <!-- 1. Hero -->
    <section class="cy-hero" id="main-content">
      <div class="cy-hero-inner">
        <img src="/assets/culpeper/culpeper-logo.png" alt="Culpeper Rugby Football Club crest" class="cy-hero-logo" />
        <p class="cy-eyebrow">Summer 2026 · Now Registering</p>
        <h1 class="cy-title">Culpeper Youth<br /><em>Rugby Football Club</em></h1>
        <p class="cy-tagline">
          New and returning players welcome. Pre-K through high school.
          No experience required.
        </p>
        <div class="cy-hero-actions">
          <a href="#contact" class="cy-btn-primary">Register for Summer Rugby</a>
          <a href="#contact" class="cy-btn-secondary">Contact the Club</a>
        </div>
      </div>
    </section>

    <!-- 2. Current Season -->
    <section class="cy-section cy-section--alt" id="season">
      <div class="cy-container">
        <p class="cy-label">Current Season</p>
        <h2 class="cy-heading">Summer 2026 <em>Rugby</em></h2>
        <p class="cy-body">
          Spring 2026 registered players are already registered for summer — no additional
          registration needed.
        </p>

        <div class="cy-schedule">
          <div class="cy-sched-item">
            <div class="cy-sched-date">May 26</div>
            <div class="cy-sched-label">Practices Begin</div>
          </div>
          <div class="cy-sched-item">
            <div class="cy-sched-date">June 6</div>
            <div class="cy-sched-label">Season Kickoff</div>
          </div>
          <div class="cy-sched-item cy-sched-item--note">
            <div class="cy-sched-date">July 5</div>
            <div class="cy-sched-label">No Games</div>
          </div>
          <div class="cy-sched-item cy-sched-item--highlight">
            <div class="cy-sched-date">July 11</div>
            <div class="cy-sched-label">Championships</div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. About the Club -->
    <section class="cy-section" id="about">
      <div class="cy-container">
        <p class="cy-label">About the Club</p>
        <h2 class="cy-heading">Youth rugby for <em>Culpeper</em> and surrounding counties.</h2>
        <p class="cy-body">
          Culpeper Youth Rugby Football Club is a community youth rugby programme open to players
          from Pre-K through high school. The club provides a welcoming, safe, and
          development-focused environment for young players at every level — from those picking
          up a rugby ball for the first time to players developing competitive skills.
        </p>

        <div class="cy-cards">
          <div class="cy-card">
            <div class="cy-card-icon" aria-hidden="true">◈</div>
            <h3 class="cy-card-title">Pre-K through High School</h3>
            <p>Age-appropriate formats for every stage. The club grows with your player.</p>
          </div>
          <div class="cy-card">
            <div class="cy-card-icon" aria-hidden="true">◈</div>
            <h3 class="cy-card-title">Tag to Tackle</h3>
            <p>
              Younger age groups play non-contact tag rugby. Tackle formats are introduced
              progressively for older players, with proper coaching and technique.
            </p>
          </div>
          <div class="cy-card">
            <div class="cy-card-icon" aria-hidden="true">◈</div>
            <h3 class="cy-card-title">Beginners Welcome</h3>
            <p>
              No experience required at any age group. Coaches work with players from their
              first session. The programme is designed to teach the game from scratch.
            </p>
          </div>
          <div class="cy-card">
            <div class="cy-card-icon" aria-hidden="true">◈</div>
            <h3 class="cy-card-title">Culpeper &amp; Beyond</h3>
            <p>
              Players from Culpeper and surrounding counties are welcome. The club serves
              the broader region, not just the town.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 4. Principles -->
    <section class="cy-section cy-section--navy-dark" id="principles">
      <div class="cy-container">
        <p class="cy-label">Club Principles</p>
        <h2 class="cy-heading">What we <em>stand for.</em></h2>

        <div class="cy-principles">
          <div class="cy-principle">
            <div class="cy-principle-num" aria-hidden="true">I</div>
            <h3 class="cy-principle-title">Unity</h3>
            <p>
              Working together towards the same goal — through triumphs and struggles.
            </p>
          </div>
          <div class="cy-principle">
            <div class="cy-principle-num" aria-hidden="true">II</div>
            <h3 class="cy-principle-title">Courage</h3>
            <p>
              Overcoming obstacles through teamwork and preparation.
            </p>
          </div>
          <div class="cy-principle">
            <div class="cy-principle-num" aria-hidden="true">III</div>
            <h3 class="cy-principle-title">Respect</h3>
            <p>
              Showing positivity to others on and off the pitch.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 5. Learn About Rugby -->
    <section class="cy-section" id="rugby">
      <div class="cy-container">
        <p class="cy-label">For Parents</p>
        <h2 class="cy-heading">Rugby is more beginner-friendly<br /><em>than you think.</em></h2>
        <p class="cy-body">
          Most parents who bring their child to a first practice have never watched a rugby match.
          That is completely normal — and not a problem. Here is what to know.
        </p>

        <div class="cy-rugby-grid">
          <div class="cy-rugby-item">
            <h3 class="cy-rugby-title">No experience required</h3>
            <p>
              Rugby coaching starts from zero. Players learn the rules, positions, and skills
              progressively. A child who has never seen rugby played before will not be out of
              place at their first session.
            </p>
          </div>
          <div class="cy-rugby-item">
            <h3 class="cy-rugby-title">Teamwork is central</h3>
            <p>
              Individual talent matters less in rugby than in most sports. Every player on the
              field has a role. The game rewards communication, decision-making, and looking out
              for teammates — not just speed or size.
            </p>
          </div>
          <div class="cy-rugby-item">
            <h3 class="cy-rugby-title">Movement and confidence</h3>
            <p>
              Rugby demands the full body — running, catching, spatial awareness, physical
              contact in age-appropriate formats. Players develop coordination and physical
              confidence at a pace that suits their age group.
            </p>
          </div>
          <div class="cy-rugby-item">
            <h3 class="cy-rugby-title">Respect is enforced</h3>
            <p>
              Rugby takes respect for opponents, referees, and teammates seriously — not as a
              stated value but as an enforced expectation at every level. Players learn that the
              culture of the sport is inseparable from the game itself.
            </p>
          </div>
          <div class="cy-rugby-item">
            <h3 class="cy-rugby-title">Tag rugby comes first</h3>
            <p>
              Younger players begin with non-contact tag rugby. Defenders pull a tag from the
              ball-carrier's belt instead of tackling. There are no scrums, contact drills, or
              physical collisions at this level. It is the recognised starting point used by
              USA Rugby's youth pathway.
            </p>
          </div>
          <div class="cy-rugby-item">
            <h3 class="cy-rugby-title">A sport for every shape</h3>
            <p>
              Rugby has a position for every body type. Forwards and backs require different
              skills, sizes, and strengths. A player who does not fit the mould for another
              sport often finds their place naturally in rugby.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 6. Get Involved -->
    <section class="cy-section cy-section--alt" id="involved">
      <div class="cy-container">
        <p class="cy-label">Get Involved</p>
        <h2 class="cy-heading">Every role <em>matters.</em></h2>
        <p class="cy-body">
          A youth rugby club depends on more than players. If any of these roles fit, we want
          to hear from you.
        </p>

        <div class="cy-roles">
          <div class="cy-role">
            <div class="cy-role-title">Player</div>
            <p>Youth players, Pre-K through high school. New and returning players welcome.</p>
          </div>
          <div class="cy-role">
            <div class="cy-role-title">Parent</div>
            <p>Helping manage sessions, coordinate logistics, chaperone, and keep the programme running week to week.</p>
          </div>
          <div class="cy-role">
            <div class="cy-role-title">Coach</div>
            <p>Rugby experience helpful but not required. Coaches from other sports are welcome. Training and certification support available.</p>
          </div>
          <div class="cy-role">
            <div class="cy-role-title">Volunteer</div>
            <p>Field setup, event support, administration — every hour contributed helps the programme operate.</p>
          </div>
          <div class="cy-role">
            <div class="cy-role-title">Sponsor</div>
            <p>Local businesses that support the club help fund kit, equipment, field costs, and player development.</p>
          </div>
          <div class="cy-role">
            <div class="cy-role-title">Supporter</div>
            <p>Want to follow the club and see it grow? That support matters too. Get in touch and stay connected.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 7. Contact / Register -->
    <section class="cy-section" id="contact">
      <div class="cy-container cy-container--narrow">
        <p class="cy-label">Register &amp; Contact</p>
        <h2 class="cy-heading">Put your name <em>forward.</em></h2>
        <p class="cy-body">
          Fill in the form below and the club will be in touch. New and returning players,
          parents, coaches, and volunteers are all welcome to reach out.
        </p>

        <div class="cy-disclaimer" role="note">
          <strong>Practice build only</strong> — replace with official registration/contact links before launch.
        </div>

        <form class="cy-form" onsubmit="return false;" aria-label="Register or contact form">
          <div class="cy-form-row">
            <div class="cy-field">
              <label for="cy-name">Full Name</label>
              <input type="text" id="cy-name" name="name" placeholder="Your name" autocomplete="name" />
            </div>
            <div class="cy-field">
              <label for="cy-email">Email Address</label>
              <input type="email" id="cy-email" name="email" placeholder="your@email.com" autocomplete="email" />
            </div>
          </div>
          <div class="cy-field">
            <label for="cy-grade">Player Age / Grade</label>
            <input type="text" id="cy-grade" name="grade" placeholder="e.g. Age 10, Grade 5 — or 'Parent/Coach/Volunteer'" />
          </div>
          <div class="cy-field">
            <label for="cy-message">Message (optional)</label>
            <textarea id="cy-message" name="message" rows="4" placeholder="Anything you'd like us to know — questions, availability, role you're interested in…"></textarea>
          </div>
          <button type="submit" class="cy-btn-primary" disabled aria-disabled="true">
            Submit — Form not yet active
          </button>
        </form>
      </div>
    </section>

    <!-- Footer -->
    <footer class="cy-footer">
      <p>Culpeper Youth Rugby Football Club · Culpeper, Virginia</p>
      <p class="cy-footer-note">Practice build — not the official CYRFC website.</p>
    </footer>

  </div><!-- /.cy-page -->
</BaseLayout>

<style>
  /* ============================================================
     CULPEPER YOUTH RFC — PAGE STYLES
     Scoped to .cy-page to avoid collision with Spotsylvania RFC.
     ============================================================ */

  .cy-page {
    background: var(--navy);
    color: #e8e4dc;
    font-family: 'Libre Baskerville', Georgia, serif;
    min-height: 100vh;
  }

  /* --- Nav -------------------------------------------------- */

  .cy-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 28px;
    background: rgba(13, 31, 45, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(200, 150, 62, 0.2);
  }

  .cy-brand {
    font-family: 'Oswald', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .cy-nav-logo {
    height: 36px;
    width: auto;
    display: block;
  }

  .cy-hero-logo {
    width: min(180px, 36vw);
    height: auto;
    margin: 0 auto 28px;
    display: block;
    filter: drop-shadow(0 4px 24px rgba(0,0,0,0.5));
  }

  .cy-nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .cy-nav-links a {
    font-family: 'Oswald', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(232, 228, 220, 0.8);
    text-decoration: none;
    padding: 6px 10px;
  }

  .cy-nav-links a:hover {
    color: var(--gold);
  }

  .cy-nav-btn {
    background: var(--gold) !important;
    color: var(--navy) !important;
    padding: 8px 16px !important;
    margin-left: 8px;
  }

  /* --- Hero ------------------------------------------------- */

  .cy-hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 24px 80px;
    background:
      radial-gradient(ellipse at center top, rgba(200, 150, 62, 0.08) 0%, transparent 60%),
      var(--navy);
  }

  .cy-hero-inner {
    max-width: 780px;
  }

  .cy-eyebrow {
    font-family: 'Oswald', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
    border: 1px solid rgba(200, 150, 62, 0.4);
    display: inline-block;
    padding: 5px 18px;
  }

  .cy-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.4rem, 6vw, 4.4rem);
    font-weight: 700;
    line-height: 1.1;
    color: #fff;
    margin-bottom: 24px;
  }

  .cy-title em {
    font-style: italic;
    color: var(--gold);
  }

  .cy-tagline {
    font-size: 1.05rem;
    line-height: 1.8;
    color: rgba(232, 228, 220, 0.72);
    max-width: 560px;
    margin: 0 auto 40px;
  }

  .cy-hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* --- Buttons ---------------------------------------------- */

  .cy-btn-primary {
    display: inline-block;
    background: var(--gold);
    color: var(--navy);
    font-family: 'Oswald', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 14px 36px;
    border: none;
    cursor: pointer;
  }

  .cy-btn-primary:hover {
    background: #d4a44a;
  }

  .cy-btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .cy-btn-secondary {
    display: inline-block;
    background: transparent;
    color: #fff;
    font-family: 'Oswald', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 13px 36px;
    border: 1px solid rgba(232, 228, 220, 0.4);
  }

  .cy-btn-secondary:hover {
    border-color: var(--gold);
    color: var(--gold);
  }

  /* --- Sections --------------------------------------------- */

  .cy-section {
    padding: 96px 24px;
  }

  .cy-section--alt {
    background: rgba(255, 255, 255, 0.03);
  }

  .cy-section--navy-dark {
    background: rgba(0, 0, 0, 0.25);
  }

  .cy-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .cy-container--narrow {
    max-width: 700px;
  }

  .cy-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.66rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }

  .cy-heading {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    line-height: 1.15;
    color: #fff;
    margin-bottom: 20px;
  }

  .cy-heading em {
    font-style: italic;
    color: var(--gold);
  }

  .cy-body {
    font-size: 1rem;
    line-height: 1.85;
    color: rgba(232, 228, 220, 0.65);
    max-width: 640px;
    margin-bottom: 56px;
  }

  /* --- Schedule --------------------------------------------- */

  .cy-schedule {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 2px;
  }

  .cy-sched-item {
    background: rgba(255, 255, 255, 0.04);
    border-top: 3px solid rgba(200, 150, 62, 0.3);
    padding: 28px 24px;
  }

  .cy-sched-item--highlight {
    border-top-color: var(--gold);
  }

  .cy-sched-item--note {
    opacity: 0.55;
  }

  .cy-sched-date {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.6rem;
    font-weight: 700;
    font-style: italic;
    color: var(--gold);
    margin-bottom: 6px;
  }

  .cy-sched-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(232, 228, 220, 0.7);
  }

  /* --- Cards ------------------------------------------------ */

  .cy-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 24px;
  }

  .cy-card {
    border: 1px solid rgba(200, 150, 62, 0.15);
    padding: 32px 28px;
  }

  .cy-card-icon {
    font-size: 1.4rem;
    color: var(--gold);
    opacity: 0.6;
    margin-bottom: 16px;
  }

  .cy-card-title {
    font-family: 'Oswald', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 12px;
  }

  .cy-card p {
    font-size: 0.93rem;
    line-height: 1.8;
    color: rgba(232, 228, 220, 0.6);
    margin: 0;
  }

  /* --- Principles ------------------------------------------- */

  .cy-principles {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 48px;
    margin-top: 8px;
  }

  .cy-principle-num {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2rem;
    font-style: italic;
    color: var(--gold);
    opacity: 0.4;
    margin-bottom: 12px;
  }

  .cy-principle-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--gold);
    margin-bottom: 14px;
  }

  .cy-principle p {
    font-size: 0.97rem;
    line-height: 1.8;
    color: rgba(232, 228, 220, 0.65);
    margin: 0;
  }

  /* --- Rugby grid ------------------------------------------- */

  .cy-rugby-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 40px 60px;
  }

  .cy-rugby-title {
    font-family: 'Oswald', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(200, 150, 62, 0.2);
  }

  .cy-rugby-item p {
    font-size: 0.93rem;
    line-height: 1.85;
    color: rgba(232, 228, 220, 0.6);
    margin: 0;
  }

  /* --- Roles ------------------------------------------------ */

  .cy-roles {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2px;
  }

  .cy-role {
    background: rgba(255, 255, 255, 0.04);
    padding: 28px 24px;
    border-top: 3px solid rgba(200, 150, 62, 0.25);
  }

  .cy-role-title {
    font-family: 'Oswald', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 12px;
  }

  .cy-role p {
    font-size: 0.92rem;
    line-height: 1.8;
    color: rgba(232, 228, 220, 0.58);
    margin: 0;
  }

  /* --- Form ------------------------------------------------- */

  .cy-disclaimer {
    background: rgba(200, 150, 62, 0.1);
    border: 1px solid rgba(200, 150, 62, 0.35);
    border-left: 4px solid var(--gold);
    padding: 14px 20px;
    font-size: 0.88rem;
    color: var(--gold);
    margin-bottom: 40px;
    line-height: 1.5;
  }

  .cy-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .cy-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .cy-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cy-field label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(232, 228, 220, 0.7);
  }

  .cy-field input,
  .cy-field textarea {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(232, 228, 220, 0.15);
    padding: 12px 16px;
    color: #fff;
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 0.93rem;
    width: 100%;
  }

  .cy-field input:focus,
  .cy-field textarea:focus {
    outline: 2px solid var(--gold);
    outline-offset: 2px;
    border-color: var(--gold);
  }

  .cy-field textarea {
    resize: vertical;
  }

  /* --- Footer ----------------------------------------------- */

  .cy-footer {
    text-align: center;
    padding: 40px 24px;
